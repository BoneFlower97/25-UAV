|RECORD=CatalogItem|ITEMTYPE=Automatic-NonVault|UNIQUEID=\ME6212C33M5G|DESIGNITEMID=ME6212C33M5G|ITEMSOURCE=|STATUS=Unknown|DESCRIPTION=ME6212 系列是以 CMOS 工艺制造的高精度，高纹波抑制比，低噪音，超快响应低压差线性稳压器。ME6212系列稳压器内置固定的参考电压源，误差修正电路，限流电路，相位补偿电路以及低内阻的MOSFET，达到高纹波抑制，低输出噪音，超快响应低压差的性能。|USERCOMMENTS=ME6212C33M5G|NOTE=|LINENUMBER=|SELECTEDPARAMETERSHASH="ME6212 系列是以 CMOS 工艺制造的高精度，高纹波抑制比，低噪音，超快响应低压差线性稳压器。ME6212系列稳压器内置固定的参考电压源，误差修正电路，限流电路，相位补偿电路以及低内阻的MOSFET，达到高纹波抑制，低输出噪音，超快响应低压差的性能。",ME6212C33M5G|COMPONENTPARAMETERS=Comment=ME6212C33M5G,"Component Kind=Standard","Description=ME6212 系列是以 CMOS 工艺制造的高精度，高纹波抑制比，低噪音，超快响应低压差线性稳压器。ME6212系列稳压器内置固定的参考电压源，误差修正电路，限流电路，相位补偿电路以及低内阻的MOSFET，达到高纹波抑制，低输出噪音，超快响应低压差的性能。",Footprint=SOT-23-5_L3.0-W1.7-P0.95-LS2.8-BL,"Ibis Model=","JLCPCB Part Class=Extended Part","Library Name=","Library Reference=ME6212C33M5G",Manufacturer=MICRONE(南京微盟),"Manufacturer Part=ME6212C33M5G",PCB3D=,"Pin Info=","Signal Integrity=",Simulation=,spicePre=U,spiceSymbolName=ME6212C33M5G,Supplier=LCSC,"Supplier Part=C81233"|CUSTOMPARAMETERS=
